# Development Dockerfile for backend
# Uses ts-node + nest start --watch for hot-reload

FROM node:22-alpine

WORKDIR /app

# Copy dependency files
COPY package*.json ./

# Install all dependencies (including dev dependencies)
RUN npm install

# Copy Prisma schema and generate client
COPY prisma ./prisma/
COPY prisma.config.ts ./

RUN npx prisma generate

# Copy source code (will be overridden by bind mount in dev)
COPY . .

EXPOSE 3000

ENV NODE_ENV=development
ENV PORT=3000

# Use NestJS watch mode for hot-reload on file changes
CMD npx prisma generate && npx prisma db push && npm run start:dev
